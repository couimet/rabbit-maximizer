# Database connection URL (Prisma format — protocol-agnostic).
# SQLite:    file:./data/rabbit-maximizer.db
# PostgreSQL: postgresql://user:pass@host:5432/rabbit
DATABASE_URL=file:./data/rabbit-maximizer.db

# Detection mode: poll or webhook
DETECTION_MODE=poll

# GitHub fine-grained Personal Access Token
# Create one at: https://github.com/settings/personal-access-tokens/new
#
# Required repository permissions:
#   issues:        read & write  (search comments, read PR comments, post retrigger)
#   pull_requests: read          (read PR status / merge state)
#   metadata:      read          (auto-included)
#
# Must be a user PAT (NOT a GitHub App token) — CodeRabbit ignores [bot] identities.
GITHUB_PAT=

# GitHub API timeout in seconds (default: 10)
GITHUB_API_TIMEOUT_SEC=10

# Log level — one of: trace, debug, info, warn, error, fatal (default: info)
LOG_LEVEL=debug

# Delay in seconds before showing the first "paused" browser notification (default: 1800)
PAUSE_NOTIFICATION_INITIAL_DELAY_SEC=1800

# Interval in seconds between repeat "paused" notifications (default: 900)
PAUSE_NOTIFICATION_REPEAT_INTERVAL_SEC=900

# Polling interval in seconds (only used when DETECTION_MODE=poll)
POLL_INTERVAL_SEC=90

# Repository filter — JSON array of user patterns or explicit repos.
# Wildcards: ["couimet/*"] searches all repos under that user (uses `user:` qualifier).
#   ⚠ Org accounts not yet supported — https://github.com/couimet/rabbit-maximizer/issues/11
# Explicit:  ["couimet/rabbit-maximizer", "other-org/specific-repo"]
# Mixed:     ["couimet/*", "other-org/single-repo"]
# A bare string (no brackets) is treated as a single-entry list.
REPO_FILTER=["couimet/*"]

# Scheduler: buffer in seconds added to the CodeRabbit review-limit wait time to avoid retrying
# exactly at the boundary (default: 60)
REVIEW_LIMIT_BUFFER_SEC=60

# Scheduler: per-PR cooldown in seconds after a successful retrigger (default: 3600 = 1 hour)
SCHEDULER_POST_COOLDOWN_SEC=3600

# Scheduler: minimum spacing in seconds between successive retriggers for the same PR (default: 180)
SCHEDULER_RETRIGGER_SPACING_SEC=180

# Scheduler: base backoff in seconds for the first unknown-error retry (default: 60)
SCHEDULER_RETRY_BACKOFF_BASE_SEC=60

# Scheduler: maximum backoff cap in seconds (default: 3600 = 1 hour)
SCHEDULER_RETRY_BACKOFF_MAX_SEC=3600

# Scheduler: tick interval in seconds (default: 10)
SCHEDULER_TICK_INTERVAL_SEC=10

# Web server port for the dashboard and API (default: 3000)
WEB_PORT=3000

# --- Webhook mode only (uncomment if DETECTION_MODE=webhook) ---
# WEBHOOK_SECRET=
# TUNNEL_URL=
