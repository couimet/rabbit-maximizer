datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// PullRequest — canonical home for PR identity and system-observed history.
//
// Column notes:
//   id                        Internal auto-increment PK.
//   uuid                      External-facing stable identifier (UUID v4).
//   title / author_login      Cached from GitHub at detection time.
//   first_seen_at             Earliest created_at across all queue rows for this PR.
//   first_review_limit_at     Earliest review-limit comment timestamp (NULL if none).
//   last_review_limit_at      Latest review-limit comment timestamp (NULL if none).
//   last_review_requested_at  Last time we posted a retrigger comment.
//   last_coderabbit_review_at Last time CodeRabbit performed a review.
//   retrigger_count           Total retrigger comments posted.
//   review_count              Total reviews actually performed by CodeRabbit.
// ---------------------------------------------------------------------------

model PullRequest {
  id                        Int       @id @default(autoincrement())
  uuid                      String    @unique @default(uuid())
  repo_full_name            String
  pr_number                 Int
  title                     String
  author_login              String
  /// One of 'open', 'merged', 'closed'. Enforced by CHECK in migration.
  pr_state                  String    @default("open")
  first_seen_at             DateTime
  first_review_limit_at     DateTime?
  last_review_limit_at      DateTime?
  last_review_requested_at  DateTime?
  last_coderabbit_review_at       DateTime?
  last_coderabbit_acknowledged_at DateTime?
  retrigger_count           Int       @default(0)
  review_count              Int       @default(0)
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt

  queueItems  ReviewQueue[]
  events      Event[]
  comments    CoderabbitComment[]

  @@index([last_coderabbit_acknowledged_at])
  @@index([last_coderabbit_review_at])
  @@index([last_review_requested_at])
  @@unique([repo_full_name, pr_number])
  @@map("pull_request")
}

// ---------------------------------------------------------------------------
// ReviewQueue — current state of pending/reviewed/failed review requests.
//
// Column notes:
//   id              Internal auto-increment PK (pagination, FKs).
//   uuid            External-facing stable identifier (UUID v4).
//   created_at      Set by us when the row is inserted.
//   updated_at      Set by us on every update.
// ---------------------------------------------------------------------------

/// Tracks a PR that needs (or has received) a review retrigger.
model ReviewQueue {
  id             Int       @id @default(autoincrement())
  /// Max 36 (UUID v4). Enforced by CHECK in the init migration.
  uuid           String    @unique @default(uuid())
  pull_request_id Int?
  /// Max 140: GitHub owner/org (<=39) + "/" + repo (<=100). Sources and CHECK in the init migration; mirrored in src/schemas/lengths.ts.
  repo_full_name String
  pr_number      Int
  /// Max 256 (GitHub PR title). Set at enqueue time.
  pr_title       String
  /// Max 25; one of 'pending' | 'retriggered' | 'reviewed' | 'failed' (CHECK in the init migration).
  status         String    @default("pending")
  attempts       Int       @default(0)
  /// Max 512 (GitHub comment URL). Source rate-limit comment that triggered this queue entry.
  source_comment_url String
  /// Numeric comment ID extracted from source_comment_url at enqueue time.
  source_comment_id Int
  /// Max 25; one of 'dashboard_retrigger_now' | 'scheduler' (CHECK in the add_trigger_source_check migration).
  trigger_source String @default("scheduler")
  /// Max 512 (GitHub comment URL). Set by markRetriggered when the retrigger comment is posted.
  retrigger_comment_url String?
  retriggered_at DateTime?
  failed_at      DateTime?
  reviewed_at    DateTime?
  queueOrder     QueueOrder?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  pullRequest   PullRequest? @relation(fields: [pull_request_id], references: [id])

  @@index([status])
  @@index([pull_request_id])
  @@map("review_queue")
}

// ---------------------------------------------------------------------------
// Event — append-only audit / debug log (one row per lifecycle transition).
//
// Three-tier shape:
//   envelope    Always-present, queried columns: ts, type, repo_full_name,
//               pr_number, correlation_id, request_id, version.
//   payload     Type-specific fields as a JSON blob (TEXT). A new event type
//               adds a new payload shape with no migration.
//   metadata    Rarely-queried provenance (git sha, build id, host, node
//               version) as a JSON blob (TEXT).
//
//   id          Internal auto-increment PK.
//   uuid        External-facing stable identifier (UUID v4).
//   ts          Set by us when we record the event (auto-default).
// ---------------------------------------------------------------------------

/// Append-only record of every lifecycle event (detected, enqueued, posted, etc.).
model Event {
  id             Int      @id @default(autoincrement())
  /// Max 36 (UUID v4).
  uuid           String   @unique @default(uuid())
  ts             DateTime @default(now())
  /// Max 40; one of 'detected' | 'enqueued' | 'retriggered' | 'bypassed' | 'failed' | 'coderabbit_review_approved' | 'coderabbit_review_changes_suggested' | 'coderabbit_review_skipped' (CHECK in the init + bypass + fix migration).
  type           String
  pull_request_id Int?
  /// Max 140: GitHub owner/org + "/" + repo. See review_queue / init migration for sources.
  repo_full_name String
  pr_number      Int
  /// Max 73 (two UUID v4 of 36 + 1 delimiter).
  correlation_id String
  /// Max 73 (two UUID v4 of 36 + 1 delimiter).
  request_id     String?
  /// Max 32 (semver, incl. prerelease/build metadata).
  version        String
  /// JSON blob; max 16384. Type-specific fields validated by Zod in src/schemas/events.ts.
  payload        String
  /// JSON blob; max 2048. Provenance (git sha, build id, host, node version).
  metadata       String?

  pullRequest     PullRequest? @relation(fields: [pull_request_id], references: [id])

  @@index([repo_full_name, pr_number, ts], map: "events_repo_pr_ts_idx")
  @@index([pull_request_id])
  @@map("events")
}

// ---------------------------------------------------------------------------
// QueueOrder — ordering of pending review queue items.
//
//   id              Auto-increment PK; provides FIFO ordering when position is NULL.
//   position        User-assigned position (1, 2, 3…). NULL until first move.
// ---------------------------------------------------------------------------

/// Determines the effective processing order of the pending queue.
model QueueOrder {
  id            Int      @id @default(autoincrement())
  queue_item_id Int      @unique
  position      Int?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  queueItem ReviewQueue @relation(fields: [queue_item_id], references: [id], onDelete: Cascade)

  @@map("queue_order")
}

// ---------------------------------------------------------------------------
// CoderabbitComment — lifecycle tracking for CodeRabbit bot comments.
//
// One row per unique GitHub comment (natural key: comment_id + is_not_deleted).
// is_not_deleted is the indexing primitive; deleted_at carries the business timestamp.
// ---------------------------------------------------------------------------

/// Tracks each unique CodeRabbit comment independently of queue items.
model CoderabbitComment {
  id              Int       @id @default(autoincrement())
  uuid            String    @unique @default(uuid())
  pull_request_id Int
  /// GitHub comment ID. Combined with is_not_deleted in a composite unique so a
  /// deleted row does not block re-creation from the same comment ID.
  comment_id      Int
  /// Max 512 (GitHub comment URL).
  url             String
  /// One of 'review_limited' | 'review_skipped' | 'review_approved' | 'review_changes_suggested' (CHECK in migration).
  comment_type    String
  /// Max 1024. First N chars of the comment body, truncated by the repository on upsert.
  last_body_preview String?
  gh_created_at   DateTime
  gh_updated_at   DateTime
  first_seen_at   DateTime
  last_seen_at    DateTime
  is_not_deleted   Boolean? @default(true)
  deleted_at       DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  pullRequest     PullRequest @relation(fields: [pull_request_id], references: [id])

  @@unique([comment_id, is_not_deleted])
  @@index([pull_request_id])
  @@index([comment_type])
  @@map("coderabbit_comment")
}

// ---------------------------------------------------------------------------
// SystemState — typed key-value store for operational state.
//
// Exactly one value column must be non-null per row, enforced by CHECK in the
// migration. Each StateKey maps to a specific value column.
// ---------------------------------------------------------------------------

/// Operational state values (poll health, scheduler status, countdown).
model SystemState {
  state_key      String  @id
  value_text     String?
  value_integer  Int?
  value_float    Float?
  value_datetime String?
  updated_at     String

  @@map("system_state")
}
