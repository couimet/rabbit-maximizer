{
  "name": "rabbit-optimizer",
  "version": "0.1.0",
  "private": true,
  "description": "Re-request CodeRabbit reviews on your PRs after hitting the hourly rate limit",
  "repository": {
    "type": "git",
    "url": "https://github.com/couimet/rabbit-optimizer"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "db:migrate": "DATABASE_URL=\"file:$PWD/data/rabbit-optimizer.db\" prisma migrate dev",
    "db:studio": "DATABASE_URL=\"file:$PWD/data/rabbit-optimizer.db\" prisma studio",
    "dev": "DATABASE_URL=\"file:$PWD/data/rabbit-optimizer.db\" tsx src/main.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
  },
  "prettier": "@couimet/eslint-config/prettier",
  "dependencies": {
    "@couimet/logger-contract": "^1.0.0",
    "@octokit/auth-token": "^6.0.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "inversify": "^8.1.1",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@couimet/dynamic-testing": "^0.1.1",
    "@couimet/eslint-config": "^0.4.0",
    "@couimet/logger-contract-testing": "^1.0.1",
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
