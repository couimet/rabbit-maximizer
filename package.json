{
  "name": "rabbit-maximizer",
  "version": "0.1.0",
  "private": true,
  "description": "Maximize CodeRabbit free-tier usage by re-requesting reviews after hitting rate limits",
  "repository": {
    "type": "git",
    "url": "https://github.com/couimet/rabbit-maximizer"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "api:types": "openapi-typescript docs/api-spec.yaml -o src/api-types.ts",
    "build": "pnpm clean && tsc",
    "clean": "jest --clearCache && rm -rf coverage",
    "db:backup": "bash scripts/db/backup.sh",
    "db:migrate": "DATABASE_URL=\"file:$(bash scripts/db/data-dir.sh)/rabbit-maximizer.db\" prisma migrate deploy",
    "db:migrate:backup": "pnpm db:backup && pnpm db:migrate",
    "db:restore": "bash scripts/db/restore.sh",
    "db:studio": "DATABASE_URL=\"file:$(bash scripts/db/data-dir.sh)/rabbit-maximizer.db\" prisma studio",
    "dev": "pnpm db:migrate:backup && pnpm local",
    "fix": "pnpm lint:fix && pnpm format:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "local": "DATABASE_URL=\"file:$(bash scripts/db/data-dir.sh)/rabbit-maximizer.db\" tsx src/main.ts",
    "test": "pnpm test:ts:unit && pnpm test:shellcheck && pnpm test:bats",
    "test:bats": "bats -r bats-tests",
    "test:bats:db": "bats bats-tests/db/",
    "test:ci": "pnpm test:ts:unit",
    "test:shellcheck": "find . \\( -name '*.sh' -o -name '*.bash' \\) -not -path './node_modules/*' -exec shellcheck {} +",
    "test:ts:unit": "pnpm clean && tsc --noEmit && NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
  },
  "prettier": "@couimet/eslint-config/prettier",
  "dependencies": {
    "@couimet/detailed-error": "^0.2.0",
    "@couimet/logger-contract": "^1.0.0",
    "@couimet/logger-contract-adapters": "^0.1.0",
    "@octokit/auth-token": "^6.0.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "inversify": "^8.1.1",
    "morgan": "^1.11.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@couimet/detailed-error-testing": "^0.1.1",
    "@couimet/dynamic-testing": "^0.1.1",
    "@couimet/eslint-config": "^0.6.0",
    "@couimet/logger-contract-testing": "^1.0.1",
    "@jest/expect": "^30.4.1",
    "@jest/globals": "^30.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^70.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
