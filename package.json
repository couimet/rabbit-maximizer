{
  "name": "rabbit-optimizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Re-request CodeRabbit reviews on your PRs after hitting the hourly rate limit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/couimet/rabbit-optimizer"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "dev": "tsx src/main.ts",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch"
  },
  "dependencies": {
    "@couimet/logger-contract": "^1.0.0",
    "@octokit/auth-token": "^5.1.2",
    "@octokit/rest": "^21.1.1",
    "@prisma/client": "^6.6.0",
    "dotenv": "^16.5.0",
    "prisma": "^6.6.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@couimet/eslint-config": "^0.1.0",
    "@couimet/logger-contract-testing": "^1.0.0",
    "@jest/globals": "^30.4.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
